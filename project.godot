; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Sellaris"
run/main_scene="res://scene/MainMenue/MainUI.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

MusicManager="*res://autoload/MusicManager.gd"
SettingsManager="*res://autoload/SettingsManager.gd"
SimClock="*uid://3e6kd3sqfbrk"
EmpireManager="*uid://d1q7tp3dnalep"
EmpirePresetManager="*res://autoload/EmpirePresetManager.gd"
EconomyManager="*res://autoload/EconomyManager.gd"
SpaceManager="*res://autoload/SpaceManager.gd"

[display]

window/size/mode=2

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
anti_aliasing/quality/msaa_2d=2
anti_aliasing/quality/msaa_3d=2
